# .gitignore — files and directories to exclude from version control

# ── Maven build output ─────────────────────────────────────────
# target/: all compiled classes, JARs, test reports — regenerated by 'mvn clean'
target/

# ── IDE-specific files ─────────────────────────────────────────
# IntelliJ IDEA project files — machine-specific, shouldn't be shared
.idea/
*.iml
*.iws
*.ipr

# Eclipse project files
.project
.classpath
.settings/

# VS Code Java settings
.vscode/

# ── Operating System files ─────────────────────────────────────
# macOS Finder metadata
.DS_Store

# Windows thumbnail cache
Thumbs.db

# ── Secrets and Credentials ───────────────────────────────────
# NEVER commit these — use environment variables instead
*.env
.env.local
credentials.properties
secrets.properties

# ── Log files ─────────────────────────────────────────────────
# Log files are generated at runtime — don't track them in git
*.log
logs/

# ── Test Reports ──────────────────────────────────────────────
# Reports are generated artifacts — regenerated on each test run
# Uncomment these if you DON'T want to commit reports to the repo
# target/cucumber-reports/
# target/allure-results/
# target/extent-reports/

# ── WebDriver Binaries ────────────────────────────────────────
# WebDriverManager downloads drivers here — excluded from VCS
.wdm/
webdriver/

# ── Temporary files ───────────────────────────────────────────
*.tmp
*.bak
*.swp
